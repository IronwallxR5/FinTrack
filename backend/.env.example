# Neon PostgreSQL connection string
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Email notifications (SendGrid)
# Sign up free at https://sendgrid.com → Settings → API Keys → Create API Key
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=notifications@yourapp.com   # must be a verified sender in SendGrid

# App URL (used in email links)
APP_URL=http://localhost:5173

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Groq AI (LLM integration)
# Get a free API key at https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
